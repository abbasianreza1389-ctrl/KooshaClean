import uuid
from django.db import models
from django.conf import settings

class TelehealthRoom(models.Model):
    PROVIDERS = [("mock","Mock"),("twilio","Twilio"),("onehundredms","OneHundredMS"),("agora","Agora")]
    id = models.UUIDField(primary_key=True, default=uuid.uuid4, editable=False)
    appointment = models.OneToOneField("scheduling.Appointment", on_delete=models.CASCADE, related_name="telehealth_room")
    code = models.SlugField(max_length=32, unique=True, db_index=True)
    provider = models.CharField(max_length=20, choices=PROVIDERS, default="mock")
    provider_room_id = models.CharField(max_length=128, blank=True, null=True)
    status = models.CharField(max_length=10, choices=[("open","Open"),("closed","Closed")], default="open")
    created_by = models.ForeignKey(settings.AUTH_USER_MODEL, on_delete=models.PROTECT, related_name="rooms_created")
    started_at = models.DateTimeField(auto_now_add=True)
    ended_at = models.DateTimeField(blank=True, null=True)
    meta = models.JSONField(default=dict, blank=True)

    class Meta: ordering = ["-started_at"]
    def __str__(self): return f"Room({self.code})"

class TeleParticipant(models.Model):
    ROLES = [("doctor","Doctor"),("patient","Patient"),("staff","Staff")]
    room = models.ForeignKey(TelehealthRoom, on_delete=models.CASCADE, related_name="participants")
    user = models.ForeignKey(settings.AUTH_USER_MODEL, on_delete=models.CASCADE, related_name="tele_participants")
    role = models.CharField(max_length=12, choices=ROLES)
    joined_at = models.DateTimeField(auto_now_add=True)
    left_at = models.DateTimeField(blank=True, null=True)
    is_connected = models.BooleanField(default=True)
    extra = models.JSONField(default=dict, blank=True)
    class Meta: unique_together = [("room","user")]

class TeleMessage(models.Model):
    room = models.ForeignKey(TelehealthRoom, on_delete=models.CASCADE, related_name="messages")
    sender = models.ForeignKey(settings.AUTH_USER_MODEL, on_delete=models.CASCADE)
    body = models.TextField()
    sent_at = models.DateTimeField(auto_now_add=True)
    class Meta: ordering = ["sent_at"]

class TeleEvent(models.Model):
    room = models.ForeignKey(TelehealthRoom, on_delete=models.CASCADE, related_name="events")
    event = models.CharField(max_length=64)
    payload = models.JSONField(default=dict, blank=True)
    created_at = models.DateTimeField(auto_now_add=True)
    class Meta: ordering = ["-created_at"]
