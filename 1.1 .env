# Django
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=<RAND>
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,koosha.local,your.domain
DJANGO_CSRF_TRUSTED_ORIGINS=https://your.domain,https://admin.your.domain
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_HSTS_SECONDS=31536000
DJANGO_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_HSTS_PRELOAD=True

# DB (Postgres توصیه می‌شود)
DB_ENGINE=postgresql
DB_NAME=koosha
DB_USER=koosha
DB_PASSWORD=StrongPass_ChangeMe
DB_HOST=127.0.0.1
DB_PORT=5432

# JWT
JWT_ACCESS_MIN=60
JWT_REFRESH_DAYS=7
JWT_ROTATE=True
JWT_BLACKLIST=True

# CORS
CORS_ALLOWED_ORIGINS=https://your.domain,https://admin.your.domain

# رسانه‌ها
MEDIA_BACKEND=local              # local|s3|minio
MEDIA_MAX_MB=25

# S3/MinIO (در صورت استفاده)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_STORAGE_BUCKET_NAME=koosha-media
AWS_S3_ENDPOINT_URL=https://s3.ir-yourcloud.com
AWS_S3_REGION_NAME=ir-teh-1
AWS_S3_OBJECT_PARAMS={"CacheControl":"max-age=31536000, public"}

# REDIS / Celery
REDIS_URL=redis://127.0.0.1:6379/0

# لاگینگ/خطا
SENTRY_DSN=
