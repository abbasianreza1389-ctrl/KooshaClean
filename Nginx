server {
  listen 80;
  server_name your.domain;
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  server_name your.domain;

  ssl_certificate     /etc/letsencrypt/live/your.domain/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/your.domain/privkey.pem;

  # هدرهای امنیتی
  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
  add_header X-Frame-Options "DENY" always;
  add_header X-Content-Type-Options "nosniff" always;
  add_header Referrer-Policy "strict-origin-when-cross-origin" always;
  add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
  # CSP (با توجه به دامنه‌های خودتان تنظیم کنید)
  add_header Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:;" always;

  # Next.js (وب‌سایت) در 3000 و داشبورد در 3100، API جنگو در 8000
  location /fa/ { proxy_pass http://127.0.0.1:3000; proxy_set_header Host $host; }
  location /en/ { proxy_pass http://127.0.0.1:3000; proxy_set_header Host $host; }
  location /ar/ { proxy_pass http://127.0.0.1:3000; proxy_set_header Host $host; }

  location /admin-dashboard/ { proxy_pass http://127.0.0.1:3100; proxy_set_header Host $host; }

  location /api/ { proxy_pass http://127.0.0.1:8000; proxy_set_header Host $host; }

  # مدیا
  location /media/ {
    alias /var/www/koosha/media/;
    add_header Cache-Control "public, max-age=31536000, immutable";
  }
}
